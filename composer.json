{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "wdog/filament-unusual",
    "description": "Extra Filament v5 form components, table columns, casts, and Artisan commands for applications using Filament Shield.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5",
        "bezhansalleh/filament-shield": "^4.1",
        "spatie/laravel-permission": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Wdog\\FilamentUnusual\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wdog\\FilamentUnusual\\FilamentUnusualServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
